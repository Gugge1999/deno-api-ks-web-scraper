{
  "tasks": {
    "dev": "deno run --watch -A src/main.ts",
    "start": "deno task migrations && deno run --watch -A src/main.ts",
    "migrations": "deno run -A src/migrations/migrations.ts"
  },
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@std/async": "jsr:@std/async@^1.2.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@tajpouria/cors": "jsr:@tajpouria/cors@^1.2.1",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/uuid": "jsr:@std/uuid@^1.1.0",

    "firebase/auth": "npm:@firebase/auth@^1.12.1",
    "firebase/app": "npm:@firebase/app@^0.14.9",
    "cheerio": "npm:cheerio@1.2.0",
    "firebase-admin": "npm:firebase-admin@^13.7.0",
    "jose": "npm:jose@^6.2.1",
    "nodemailer": "npm:nodemailer@^8.0.2",
    "postgres": "npm:postgres@3.4.8",
    "postgres-shift": "npm:postgres-shift@^0.1.0",
    "winston": "npm:winston@^3.19.0"
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "lineWidth": 135,
    "include": ["src/"],
    "exclude": ["node_modules/", ".VSCodeCounter/"]
  },
  "exclude": ["node_modules/", ".VSCodeCounter/"]
}

